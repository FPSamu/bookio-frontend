{
  "designSystem": {
    "borderRadius": {
      "none": "0px",
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "2xl": "24px",
      "full": "9999px"
    },
    "spacing": {
      "unit": "8px",
      "section": "96px",
      "container": "1200px"
    },
    "typography": {
      "hero": { "size": "64px", "weight": 800, "lineHeight": 1.1 },
      "h2": { "size": "40px", "weight": 700, "lineHeight": 1.2 },
      "h3": { "size": "24px", "weight": 600, "lineHeight": 1.3 },
      "body": { "size": "16px", "weight": 400, "lineHeight": 1.6 },
      "small": { "size": "13px", "weight": 400, "lineHeight": 1.5 },
      "stat": { "size": "48px", "weight": 800, "lineHeight": 1 }
    },
    "shadows": {
      "card": "0 4px 24px rgba(0,0,0,0.08)",
      "cardHover": "0 8px 40px rgba(0,0,0,0.14)",
      "floating": "0 16px 48px rgba(0,0,0,0.16)"
    }
  },

  "components": {

    "Navbar": {
      "description": "Fixed top navigation bar",
      "layout": "flex, horizontal, space-between, vertically centered",
      "height": "64px",
      "width": "100%",
      "padding": "0 32px",
      "borderRadius": "none",
      "border": "1px solid bottom only",
      "children": {
        "Logo": {
          "layout": "flex, horizontal, gap 8px, vertically centered",
          "icon": { "size": "28px", "shape": "rounded square" },
          "text": { "weight": 700, "size": "18px" }
        },
        "NavLinks": {
          "layout": "flex, horizontal, gap 32px, centered",
          "item": { "size": "14px", "weight": 500, "cursor": "pointer" }
        },
        "NavActions": {
          "layout": "flex, horizontal, gap 12px, vertically centered",
          "primaryButton": {
            "shape": "pill",
            "borderRadius": "9999px",
            "padding": "10px 20px",
            "fontSize": "14px",
            "fontWeight": 600
          },
          "avatar": {
            "shape": "circle",
            "size": "34px",
            "overflow": "hidden"
          }
        }
      }
    },

    "SectionBadge": {
      "description": "Small pill-shaped label above section headings to indicate topic or tag",
      "shape": "pill",
      "borderRadius": "9999px",
      "padding": "4px 14px",
      "fontSize": "12px",
      "fontWeight": 600,
      "display": "inline-flex",
      "alignItems": "center",
      "gap": "6px",
      "border": "1px solid",
      "dotIndicator": {
        "size": "6px",
        "shape": "circle"
      }
    },

    "HeroSection": {
      "description": "Full-width opening section with two-column layout",
      "layout": "grid, 2 columns (55% / 45%), gap 64px",
      "padding": "80px 0",
      "verticalAlignment": "center",
      "left": {
        "layout": "flex, column, gap 24px",
        "badge": { "ref": "SectionBadge" },
        "heading": {
          "fontSize": "60px",
          "fontWeight": 800,
          "lineHeight": 1.1,
          "maxWidth": "560px"
        },
        "subtext": {
          "fontSize": "17px",
          "fontWeight": 400,
          "lineHeight": 1.6,
          "maxWidth": "480px"
        },
        "ctaGroup": {
          "layout": "flex, horizontal, gap 12px, vertically centered",
          "primaryCTA": { "ref": "ButtonPrimary" },
          "secondaryCTA": { "ref": "ButtonTextLink" }
        },
        "trustBadges": {
          "layout": "flex, horizontal, gap 32px",
          "item": {
            "layout": "flex, column, gap 2px",
            "value": { "fontSize": "20px", "fontWeight": 700 },
            "label": { "fontSize": "12px", "fontWeight": 400 }
          }
        }
      },
      "right": {
        "layout": "relative, stacked floating cards",
        "mainCard": { "ref": "DashboardWidget" },
        "overlappingCard": { "ref": "StatMiniCard", "position": "absolute, overlapping" }
      }
    },

    "ButtonPrimary": {
      "description": "Main call-to-action button, pill shaped",
      "shape": "pill",
      "borderRadius": "9999px",
      "padding": "12px 24px",
      "fontSize": "14px",
      "fontWeight": 600,
      "display": "inline-flex",
      "alignItems": "center",
      "gap": "8px",
      "cursor": "pointer"
    },

    "ButtonSecondary": {
      "description": "Outlined or ghost pill button",
      "shape": "pill",
      "borderRadius": "9999px",
      "padding": "12px 24px",
      "fontSize": "14px",
      "fontWeight": 600,
      "border": "1.5px solid",
      "display": "inline-flex",
      "alignItems": "center",
      "gap": "8px",
      "cursor": "pointer"
    },

    "ButtonTextLink": {
      "description": "Text-only link button with arrow icon",
      "padding": "0",
      "fontSize": "14px",
      "fontWeight": 600,
      "display": "inline-flex",
      "alignItems": "center",
      "gap": "6px",
      "cursor": "pointer",
      "underline": "none"
    },

    "DashboardWidget": {
      "description": "Floating dashboard preview card used in hero and feature sections",
      "borderRadius": "16px",
      "padding": "20px",
      "shadow": "0 16px 48px rgba(0,0,0,0.16)",
      "border": "1px solid",
      "layout": "flex, column, gap 16px",
      "children": {
        "header": {
          "layout": "flex, horizontal, space-between",
          "title": { "fontSize": "13px", "fontWeight": 600 },
          "badge": { "ref": "StatusBadge" }
        },
        "statRow": {
          "layout": "flex, horizontal, gap 16px",
          "stat": { "ref": "StatMiniCard" }
        },
        "chartArea": {
          "height": "80px",
          "layout": "flex, row, align-end, gap 4px",
          "bar": {
            "width": "8px",
            "borderRadius": "4px 4px 0 0"
          }
        }
      }
    },

    "StatMiniCard": {
      "description": "Small floating card showing a single metric",
      "borderRadius": "12px",
      "padding": "12px 16px",
      "shadow": "0 4px 16px rgba(0,0,0,0.10)",
      "border": "1px solid",
      "layout": "flex, column, gap 4px",
      "value": { "fontSize": "20px", "fontWeight": 700 },
      "label": { "fontSize": "11px", "fontWeight": 400 }
    },

    "StatusBadge": {
      "description": "Tiny pill badge for status labels (e.g. 'Live', 'Active')",
      "shape": "pill",
      "borderRadius": "9999px",
      "padding": "2px 10px",
      "fontSize": "11px",
      "fontWeight": 600
    },

    "FeatureGrid": {
      "description": "Grid section presenting multiple product features",
      "layout": "grid, 4 columns, gap 32px",
      "padding": "64px 0",
      "card": {
        "ref": "FeatureCard"
      }
    },

    "FeatureCard": {
      "description": "Individual feature card with icon, title, description and link",
      "borderRadius": "0",
      "padding": "0",
      "border": "none",
      "layout": "flex, column, gap 12px",
      "icon": {
        "size": "32px",
        "containerSize": "40px",
        "containerShape": "rounded square",
        "borderRadius": "8px"
      },
      "title": { "fontSize": "16px", "fontWeight": 600 },
      "description": { "fontSize": "13px", "lineHeight": 1.6, "maxLines": 3 },
      "link": {
        "fontSize": "13px",
        "fontWeight": 600,
        "display": "inline-flex",
        "alignItems": "center",
        "gap": "4px"
      }
    },

    "SplitSection": {
      "description": "Two-column section: text content on one side, UI mockup on the other",
      "layout": "grid, 2 columns (50% / 50%), gap 64px",
      "padding": "80px 0",
      "verticalAlignment": "center",
      "textSide": {
        "layout": "flex, column, gap 20px",
        "badge": { "ref": "SectionBadge" },
        "heading": { "fontSize": "36px", "fontWeight": 700, "lineHeight": 1.2 },
        "body": { "fontSize": "15px", "lineHeight": 1.6 },
        "cta": { "ref": "ButtonPrimary" }
      },
      "mockupSide": {
        "layout": "relative",
        "overflow": "hidden",
        "borderRadius": "16px",
        "shadow": "0 16px 48px rgba(0,0,0,0.12)"
      }
    },

    "TaskListMockup": {
      "description": "UI mockup showing a list of tasks with filters and tabs",
      "borderRadius": "14px",
      "padding": "16px",
      "layout": "flex, column, gap 8px",
      "tabBar": {
        "layout": "flex, horizontal, gap 0",
        "tab": {
          "padding": "6px 14px",
          "borderRadius": "9999px",
          "fontSize": "12px",
          "fontWeight": 500
        }
      },
      "taskItem": {
        "layout": "flex, horizontal, vertically centered, gap 10px",
        "height": "36px",
        "borderRadius": "8px",
        "padding": "0 10px",
        "checkbox": { "size": "14px", "borderRadius": "4px", "border": "1.5px solid" },
        "label": { "fontSize": "13px", "fontWeight": 500 },
        "priorityDot": { "size": "8px", "shape": "circle" },
        "chip": {
          "borderRadius": "9999px",
          "padding": "2px 8px",
          "fontSize": "10px",
          "fontWeight": 600
        }
      }
    },

    "BarChart": {
      "description": "Simple vertical bar chart used in mockups and stats",
      "layout": "flex, horizontal, align-end, gap 4px",
      "bar": {
        "width": "12px",
        "borderRadius": "4px 4px 0 0",
        "minHeight": "8px"
      },
      "axis": { "height": "1px", "width": "100%" }
    },

    "IntegrationLogo": {
      "description": "Circular icon representing a third-party integration",
      "shape": "circle",
      "size": "48px",
      "border": "1px solid",
      "shadow": "0 2px 8px rgba(0,0,0,0.10)",
      "overflow": "hidden",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "icon": { "size": "24px" }
    },

    "IntegrationGrid": {
      "description": "Scattered or orbiting layout of integration logos",
      "layout": "relative, absolute-positioned children",
      "centerIcon": {
        "ref": "IntegrationLogo",
        "size": "64px"
      }
    },

    "StatsRow": {
      "description": "Horizontal row of large metric numbers",
      "layout": "flex, horizontal, gap 64px, centered",
      "padding": "48px 0",
      "statItem": {
        "layout": "flex, column, gap 4px, centered",
        "value": { "fontSize": "48px", "fontWeight": 800 },
        "label": { "fontSize": "13px", "fontWeight": 400, "textAlign": "center" }
      },
      "divider": {
        "width": "1px",
        "height": "48px"
      }
    },

    "SectionHeader": {
      "description": "Centered heading block used above feature/content sections",
      "layout": "flex, column, gap 12px, centered, textAlign center",
      "maxWidth": "640px",
      "margin": "0 auto 48px",
      "badge": { "ref": "SectionBadge" },
      "heading": { "fontSize": "40px", "fontWeight": 700 },
      "subtext": { "fontSize": "16px", "lineHeight": 1.6 }
    },

    "TestimonialCard": {
      "description": "Customer quote card with author info and star rating",
      "borderRadius": "16px",
      "padding": "28px",
      "border": "1px solid",
      "shadow": "0 4px 24px rgba(0,0,0,0.07)",
      "layout": "flex, column, gap 16px",
      "quote": { "fontSize": "15px", "lineHeight": 1.7, "fontStyle": "italic" },
      "starRating": {
        "layout": "flex, horizontal, gap 4px",
        "star": { "size": "14px" }
      },
      "author": {
        "layout": "flex, horizontal, gap 10px, vertically centered",
        "avatar": { "size": "36px", "shape": "circle", "overflow": "hidden" },
        "info": {
          "layout": "flex, column, gap 2px",
          "name": { "fontSize": "14px", "fontWeight": 600 },
          "role": { "fontSize": "12px", "fontWeight": 400 }
        }
      }
    },

    "TestimonialGrid": {
      "description": "Grid of testimonial cards",
      "layout": "grid, 2-3 columns, gap 24px"
    },

    "AvatarStack": {
      "description": "Overlapping circular avatars shown together",
      "layout": "flex, horizontal",
      "avatar": {
        "size": "32px",
        "shape": "circle",
        "border": "2px solid background",
        "marginLeft": "-8px",
        "overflow": "hidden"
      }
    },

    "ToggleSwitch": {
      "description": "On/off toggle control",
      "width": "36px",
      "height": "20px",
      "borderRadius": "9999px",
      "border": "none",
      "thumb": {
        "size": "14px",
        "shape": "circle",
        "shadow": "0 1px 4px rgba(0,0,0,0.2)"
      }
    },

    "SalesOverviewCard": {
      "description": "Dashboard card showing key financial metrics and a bar chart",
      "borderRadius": "16px",
      "padding": "24px",
      "shadow": "0 4px 24px rgba(0,0,0,0.08)",
      "border": "1px solid",
      "layout": "flex, column, gap 20px",
      "header": {
        "layout": "flex, horizontal, space-between",
        "title": { "fontSize": "16px", "fontWeight": 600 },
        "toggle": { "ref": "ToggleSwitch" }
      },
      "metricsRow": {
        "layout": "grid, 3 columns, gap 16px",
        "metric": {
          "layout": "flex, column, gap 4px",
          "label": { "fontSize": "12px" },
          "value": { "fontSize": "22px", "fontWeight": 700 }
        }
      },
      "chart": { "ref": "BarChart" }
    },

    "CTASection": {
      "description": "Centered bottom call-to-action section",
      "layout": "flex, column, gap 24px, centered, textAlign center",
      "padding": "80px 0",
      "badge": { "ref": "SectionBadge" },
      "heading": { "fontSize": "48px", "fontWeight": 800, "maxWidth": "600px" },
      "buttonGroup": {
        "layout": "flex, horizontal, gap 12px, centered",
        "primary": { "ref": "ButtonPrimary" },
        "secondary": { "ref": "ButtonTextLink" }
      }
    },

    "Footer": {
      "description": "Multi-column footer with logo, description, and link sections",
      "layout": "grid, 4-5 columns, gap 48px",
      "padding": "64px 0 32px",
      "brandColumn": {
        "layout": "flex, column, gap 16px",
        "logo": { "ref": "Navbar.Logo" },
        "description": { "fontSize": "13px", "lineHeight": 1.7, "maxWidth": "240px" }
      },
      "linkColumn": {
        "layout": "flex, column, gap 12px",
        "heading": { "fontSize": "13px", "fontWeight": 600 },
        "link": { "fontSize": "13px", "fontWeight": 400 }
      },
      "bottomBar": {
        "layout": "flex, horizontal, space-between, vertically centered",
        "paddingTop": "24px",
        "borderTop": "1px solid",
        "copyright": { "fontSize": "12px" }
      }
    },

    "PaginationDots": {
      "description": "Carousel or slider pagination indicator",
      "layout": "flex, horizontal, gap 6px, centered",
      "dot": {
        "size": "8px",
        "shape": "circle",
        "activeDot": { "width": "24px", "borderRadius": "9999px" }
      }
    },

    "DividerLine": {
      "description": "Thin horizontal separator between sections",
      "height": "1px",
      "width": "100%"
    }
  }
}
